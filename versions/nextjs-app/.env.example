# ── Sanity CMS ───────────────────────────────────────────────────────────────
# Create a project at https://sanity.io and copy the values from the dashboard.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# ── Stripe (stub — no live charges) ──────────────────────────────────────────
# Obtain from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Stripe webhook secret — set via `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_

# ── Age gate ──────────────────────────────────────────────────────────────────
# Cookie name used by middleware — keep in sync with middleware.ts
NEXT_PUBLIC_AGE_GATE_COOKIE=dorst-age-verified

# ── Locale ────────────────────────────────────────────────────────────────────
# Default locale served to new visitors before they set a preference.
# Supported: bg | en
NEXT_PUBLIC_DEFAULT_LOCALE=bg

# ── Analytics ─────────────────────────────────────────────────────────────────
# Vercel Analytics is injected automatically on Vercel — no key needed.
# If self-hosting, remove the <Analytics /> component from app/layout.tsx.
